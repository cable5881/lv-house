.mine-page { padding: 32rpx; min-height: 100vh; background: #F7F4ED; }

/* 头像卡片 */
.profile-card { display: flex; align-items: center; padding: 40rpx 32rpx; margin-bottom: 32rpx; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; border: 2px solid #ECEAE4; margin-right: 32rpx; }
.avatar-default { opacity: 0.5; }
.login-hint { font-size: 32rpx; color: #5F5F5D; }
.user-info { flex: 1; }
.user-name { font-size: 32rpx; font-weight: 600; display: block; margin-bottom: 8rpx; }
.user-detail { font-size: 24rpx; color: #5F5F5D; display: block; margin-bottom: 4rpx; }
.admin-badge { display: inline-block; font-size: 20rpx; color: #FCFBF8; background: #1C1C1C; border-radius: 9999rpx; padding: 4rpx 16rpx; margin-top: 8rpx; }

/* 菜单 */
.menu-list { background: #fff; border-radius: 24rpx; border: 1px solid #ECEAE4; overflow: hidden; margin-bottom: 32rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; border-bottom: 1px solid #ECEAE4; font-size: 28rpx; }
.menu-item:last-child { border-bottom: none; }
.arrow { color: #5F5F5D; }

.favorite-section { margin-bottom: 32rpx; }
.favorite-count { font-size: 24rpx; color: #5F5F5D; }
.goods-grid { display: flex; flex-wrap: wrap; margin: 0 -10rpx; }
.goods-grid-item { width: 50%; padding: 0 10rpx; box-sizing: border-box; }
.loading-more { text-align: center; color: #5F5F5D; font-size: 24rpx; padding: 24rpx 0; }

/* 编辑弹窗 */
.edit-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 1000; display: flex; align-items: flex-end; }
.edit-panel { background: #fff; width: 100%; border-radius: 24rpx 24rpx 0 0; padding: 40rpx 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); }
.edit-title { font-size: 32rpx; font-weight: 600; display: block; margin-bottom: 32rpx; }
.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 26rpx; font-weight: 500; display: block; margin-bottom: 12rpx; }
.form-input { background: rgba(28,28,28,0.04); border: 1px solid #ECEAE4; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; }

/* 退出 */
.logout-section { margin-top: 64rpx; }
