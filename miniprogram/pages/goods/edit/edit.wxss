.edit-page { padding-top: 20rpx; padding-bottom: 40rpx; }
.form-group { margin-bottom: 36rpx; }
.form-label { font-size: 28rpx; font-weight: 500; color: #1C1C1C; margin-bottom: 12rpx; display: block; }
.form-input {
  background: #FFFFFF;
  border: 2rpx solid #ECEAE4;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1C1C1C;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  box-sizing: border-box;
}
.form-textarea {
  background: #FFFFFF;
  border: 2rpx solid #ECEAE4;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1C1C1C;
  width: 100%;
  min-height: 200rpx;
  line-height: 1.6;
  box-sizing: border-box;
}
.picker-value {
  color: #1C1C1C;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #ECEAE4;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 图片 */
.image-grid { display: flex; flex-wrap: wrap; }
.image-item { width: 160rpx; height: 160rpx; margin-right: 16rpx; margin-bottom: 16rpx; border-radius: 12rpx; overflow: hidden; position: relative; }
.preview-img { width: 100%; height: 100%; }
.remove-btn { position: absolute; top: 0; right: 0; width: 40rpx; height: 40rpx; background: rgba(0,0,0,0.5); color: #fff; font-size: 28rpx; text-align: center; line-height: 40rpx; border-radius: 0 12rpx 0 12rpx; }
.add-btn { background: #FFFFFF; border: 2rpx dashed #ECEAE4; display: flex; align-items: center; justify-content: center; }
.add-icon { font-size: 48rpx; color: #5F5F5D; }

/* 星星预览 */
.rating-preview { margin-top: 12rpx; }

/* 多选 */
.checkbox-group { display: flex; flex-wrap: wrap; }
.checkbox-item { padding: 12rpx 28rpx; border-radius: 9999rpx; background: #FFFFFF; border: 2rpx solid #ECEAE4; font-size: 26rpx; color: #5F5F5D; margin-right: 16rpx; margin-bottom: 12rpx; line-height: 1.4; }
.checkbox-item.checked { background: #1C1C1C; color: #FCFBF8; border-color: #1C1C1C; }
.add-dimension-btn { display: inline-flex; align-items: center; padding: 12rpx 28rpx; border-radius: 9999rpx; background: #FFFFFF; border: 2rpx dashed #ECEAE4; font-size: 26rpx; color: #5F5F5D; margin-bottom: 12rpx; line-height: 1.4; }

/* 内联新增行 */
.inline-add-row {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 12rpx;
}
.inline-add-input {
  flex: 1;
  background: #FFFFFF;
  border: 2rpx solid #FFB800;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1C1C1C;
  height: 72rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}
.inline-add-confirm {
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #1C1C1C;
  color: #FCFBF8;
  border-radius: 12rpx;
  font-size: 26rpx;
  text-align: center;
  white-space: nowrap;
}
.inline-add-cancel {
  padding: 0 20rpx;
  height: 72rpx;
  line-height: 72rpx;
  color: #5F5F5D;
  font-size: 26rpx;
  text-align: center;
  white-space: nowrap;
}

/* 按钮 */
.btn-group { display: flex; margin-top: 48rpx; }
.btn-group .btn-ghost, .btn-group .btn-primary { flex: 1; margin: 0 8rpx; }
.delete-row { text-align: center; margin-top: 32rpx; }
.delete-text { color: #E85D5D; font-size: 28rpx; }
