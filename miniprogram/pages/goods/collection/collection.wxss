.collection-header { position: relative; }
.header-cover { width: 100%; height: 400rpx; }
.header-info { padding: 32rpx; background: #fff; border-radius: 24rpx 24rpx 0 0; margin-top: -40rpx; position: relative; }
.header-period { font-size: 24rpx; color: #5F5F5D; display: block; margin-bottom: 8rpx; }
.header-title { font-size: 32rpx; font-weight: 600; display: block; margin-bottom: 8rpx; }
.header-desc { font-size: 26rpx; color: #5F5F5D; display: block; }
.goods-grid { display: flex; flex-wrap: wrap; justify-content: space-between; padding-top: 24rpx; }
.goods-grid-item { width: 48.5%; }
