/* ===== Lovable Design System - 微信小程序适配 ===== */
page {
  --color-bg: #F7F4ED;
  --color-text-primary: #1C1C1C;
  --color-text-secondary: #5F5F5D;
  --color-text-inverse: #FCFBF8;
  --color-border-light: #ECEAE4;
  --color-border-interactive: rgba(28,28,28,0.4);
  --color-star: #FFB800;
  --color-danger: #E85D5D;
  --color-tag-bg: rgba(28,28,28,0.04);
  --color-input-bg: rgba(28,28,28,0.04);
  --color-card-bg: #FFFFFF;
  --radius-button: 12rpx;
  --radius-card: 24rpx;
  --radius-pill: 9999rpx;
  --radius-input: 12rpx;
  --spacing-page: 32rpx;
  --spacing-card: 24rpx;
  --spacing-section: 48rpx;

  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue',
               'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

/* Global utility classes */
.page-container {
  padding: 0 var(--spacing-page);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-header .view-all {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.card {
  background: var(--color-card-bg);
  border-radius: var(--radius-card);
  border: 1px solid var(--color-border-light);
  overflow: hidden;
}

.btn-primary {
  background: var(--color-text-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-button);
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 0;
  border: none;
}

.btn-ghost {
  background: transparent;
  color: var(--color-text-primary);
  border: 1px solid var(--color-border-interactive);
  border-radius: var(--radius-button);
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 0;
}

.btn-danger {
  background: transparent;
  color: var(--color-danger);
  border: 1px solid var(--color-danger);
  border-radius: var(--radius-button);
  text-align: center;
  font-size: 28rpx;
  padding: 20rpx 0;
}

.tag-pill {
  display: inline-block;
  background: var(--color-tag-bg);
  border-radius: var(--radius-pill);
  padding: 6rpx 20rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.price-text {
  color: #E85D5D;
  font-weight: 600;
}

.text-secondary {
  color: var(--color-text-secondary);
  font-size: 24rpx;
}
